model {
    for (i in 1:N_boys) {
    for (j in 1:N_time) {
      boys[i, j] ~ dnorm(mu[j], tau)
    }
  }
  
    for (j in 1:N_time) {
    mu[j] <- beta0 + beta1 * t_obs[j] + beta2 * (1 - exp(-(beta3 / beta2) * t_obs[j]))
  }
  
    beta0 ~ dnorm(0, 0.0001) T(0, )
  beta1 ~ dnorm(0, 0.0001) T(0, )
  beta2 ~ dnorm(0, 0.0001) T(0, )
  beta3 ~ dnorm(0, 0.0001) T(0, )
  
   tau ~ dgamma(0.0001, 0.0001)
  sigma <- 1 / sqrt(tau)
}